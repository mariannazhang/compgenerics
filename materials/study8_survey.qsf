tionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/\/ function to randomize string\n\tfunction randomizeString(str) {\n\t\tconst array = str.split('');\n\t\tlet currentIndex = array.length, randomIndex;\n\t\t\n\t\twhile (currentIndex != 0) {\n\t\t\trandomIndex = Math.floor(Math.random() * currentIndex);\n\t\t\tcurrentIndex--;\n\t\t\t\n\t\t\t[array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];\n\t\t}\n\t\t\n\t\treturn array.join('');\n\t}\n\t\n\t\/\/ parse condition into number of generics and total utterances\n\tconst condition = \"${e:\/\/Field\/condition}\"\n\tconst num_generics = parseInt(condition.substring(0, condition.lastIndexOf('\/')), 10);\n\tconst total_utt = parseInt(condition.substring(condition.lastIndexOf('\/') + 1), 10);\n\t\n\t\/\/ validate parse\n\tif (isNaN(num_generics) || isNaN(total_utt) || num_generics > total_utt) {\n\t\tconsole.error(\"Invalid condition parse\");\n\t\treturn;\n\t}\n\t\n\t\/\/ construct trials string (8 = GGGGGGGGSSSSSSSS)\n\tvar trials = \"G\".repeat(num_generics) + \"S\".repeat(total_utt - num_generics);\n\t\n\t\/\/ randomize trials string\n\ttrials = randomizeString(trials)\n\t\n\t\/\/ reassign trials to embedded data\n\tQualtrics.SurveyEngine.setEmbeddedData('trials', trials);\n\t\n\t\/\/ debugging: print trials\n\tjQuery(\"#\"+this.questionId+\" .QuestionText\").html(\"trials: \" + trials + \"\\n\" + \"condition: \" + condition.toString());\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});"}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID141","SecondaryAttribute":"condition = ${e:\/\/Field\/condition} trials = ${e:\/\/Field\/trials}","TertiaryAttribute":null,"Payload":{"QuestionText":"condition = ${e:\/\/Field\/condition}<br>trials = ${e:\/\/Field\/trials}<br>","DefaultChoices":false,"DataExportTag":"assign_trials_check","QuestionID":"QID141","QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"condition = ${e:\/\/Field\/condition} trials = ${e:\/\/Field\/trials}","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID142","SecondaryAttribute":"video class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\" video video video video class=\"qmedi...","TertiaryAttribute":null,"Payload":{"QuestionText":"<video autoplay=\"\">\n  <source type=\"video\/mp4\" src=\"movie.mp4\">\n  <source type=\"video\/ogg\" src=\"movie.ogg\">\nvideo class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\"&gt;video video video video class=\"qmedia\" controls=\"true\" height=\"480\" preload=\"auto\" width=\"640\"&gt;<source type=\"video\/mp4\" src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_ahfgtvRavjHKk1o\"><\/video>","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"video class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\" video video video video class=\"qmedi...","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DataVisibility":{"Private":false,"Hidden":false},"QuestionText_Unsafe":"<video autoplay=\"\">\n  <source type=\"video\/mp4\" src=\"movie.mp4\">\n  <source type=\"video\/ogg\" src=\"movie.ogg\">\nvideo class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\"&gt;video video video video class=\"qmedia\" controls=\"true\" height=\"480\" preload=\"auto\" width=\"640\"&gt;<source type=\"video\/mp4\" src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_ahfgtvRavjHKk1o\"><\/video>","DataExportTag":"Q142","QuestionID":"QID142"}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID143","SecondaryAttribute":"Please advance to start the videos.","TertiaryAttribute":null,"Payload":{"QuestionText":"Please advance to start the videos.","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"Please advance to start the videos.","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\n\t\/\/ function to randomize string\n\tfunction randomizeString(str) {\n\t\tconst array = str.split('');\n\t\tlet currentIndex = array.length, randomIndex;\n\t\t\n\t\twhile (currentIndex != 0) {\n\t\t\trandomIndex = Math.floor(Math.random() * currentIndex);\n\t\t\tcurrentIndex--;\n\t\t\t\n\t\t\t[array[currentIndex], array[randomIndex]] = [array[randomIndex], array[currentIndex]];\n\t\t}\n\t\t\n\t\treturn array.join('');\n\t}\n\t\n\t\/\/ parse condition into number of generics and total utterances\n\t\/\/ const condition = \"${e:\/\/Field\/condition}\"\n\tconst condition = Qualtrics.SurveyEngine.getEmbeddedData('condition');\n\tconst num_generics = parseInt(condition.substring(0, condition.lastIndexOf('\/')), 10);\n\tconst total_utt = parseInt(condition.substring(condition.lastIndexOf('\/') + 1), 10);\n\t\n\t\/\/ construct training structure (eg GGGGGGGGSSSSSSSS)\n\tvar training_structure = \"G\".repeat(num_generics) + \"S\".repeat(total_utt - num_generics);\n\t\n\t\/\/ randomize trials string\n\ttraining_structure = randomizeString(training_structure);\n\t\n\t\/\/ reassign variables to embedded data, so they can be referenced later\n\t\/\/ Qualtrics.SurveyEngine.setJSEmbeddedData('num_generics', num_generics);\n\tQualtrics.SurveyEngine.setEmbeddedData('num_generics', num_generics);\n\tQualtrics.SurveyEngine.setEmbeddedData('total_utt', total_utt);\n\tQualtrics.SurveyEngine.setEmbeddedData('training_structure', training_structure);\n\t\n\t\/\/ debugging: print trials\n\t\/\/ jQuery(\"#\"+this.questionId+\" .QuestionText\").html(\"SHOWN FOR DEMO PURPOSES ONLY\" + \"<br>\" + \"training structure: \" + training_structure + \"<br>\" + \"num_generics: \" + num_generics.toString() + \", \" + \"total_utt: \" + total_utt.toString());\n\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/*Place your JavaScript here to run when the page is fully displayed*\/\n\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","QuestionText_Unsafe":"&nbsp;","DataExportTag":"assign_training","QuestionID":"QID143"}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID144","SecondaryAttribute":"question text edited in javascript ","TertiaryAttribute":null,"Payload":{"QuestionText":"question text edited in javascript&nbsp;","QuestionJS":"Qualtrics.SurveyEngine.addOnload(function()\n{\t\n\t\/\/ get loop number (=trial number)\n\tvar currentLoop = \"${lm:\/\/CurrentLoopNumber}\";\n\t\n\t\/\/ add trial feature to feature list\n\t\/\/ var training_features_order = Qualtrics.SurveyEngine.getJSEmbeddedData(\"training_features_order\"); \/\/ requires embedded data variable to be prefixed with __js_\n\tvar training_features_order = Qualtrics.SurveyEngine.getEmbeddedData(\"training_features_order\");\n\tvar trial_feature = \"${lm:\/\/Field\/3}\";\n\tif(currentLoop == 1){\n\t\ttraining_features_order = trial_feature;\n\t} else {\n\t\ttraining_features_order += \"|\" + trial_feature; \/\/ using Qualtrics syntax for display order\n\t}\n\t\n\t\/\/ Qualtrics.SurveyEngine.setJSEmbeddedData('training_features_order', training_features_order);\n\tQualtrics.SurveyEngine.setEmbeddedData('training_features_order', training_features_order);\n\t\n\t\n\t\/\/ get trial type from training structure\n\t\/\/ const training_structure = Qualtrics.SurveyEngine.getJSEmbeddedData(\"training_structure\");\n\tconst training_structure = Qualtrics.SurveyEngine.getEmbeddedData(\"training_structure\");\n\tvar thisTrial = training_structure[parseInt(currentLoop) - 1] || null;\n\t\n\t\/\/ get the corresponding video for this trial\n\tvar vid_ID = \"\";\n\tswitch(thisTrial) {\n\t\tcase \"G\":\n\t\t\tvid_ID = \"${lm:\/\/Field\/1}\";\n\t\t\tbreak;\n\t\tcase \"S\":\n\t\t\tvid_ID = \"${lm:\/\/Field\/2}\";\n\t\t\tbreak;\n\t\tdefault:\n\t\t\tvid_ID = \"Error: Invalid vid ID\";\n\t\t\tconsole.error(\"Invalid vid ID:\", thisTrial);\n\t}\n\t\n\t\/\/ show video\n\tjQuery(\"#\"+this.questionId+\" .QuestionText\").html(\n\t\t\"<video id='vidid' autoplay=true playsinline=true video class='qmedia' width='100%' preload='auto'><source src='https:\/\/nyu.qualtrics.com\/CP\/File.php?F=\" + vid_ID + \"' \" + \"type='video\/mp4' \/> <embed align='middle' autoplay='true' bgcolor='white' class='qmedia' controller='true' pluginspage='http:\/\/www.apple.com\/quicktime\/download\/' type='video\/quicktime'\/><\/video>\"\n\t);\n\t\n});\n\nQualtrics.SurveyEngine.addOnReady(function()\n{\n\t\/\/ Disable next button until video is done\n\tvar qobj = this;\n\tqobj.hideNextButton();\n\tjQuery(\"#vidid\").on(\"ended\", function() { qobj.showNextButton() });\n\t\/\/ Auto advance once video ends\n\tjQuery(\"#vidid\").on(\"ended\", function(event) {          $('NextButton').click();  });\n});\n\nQualtrics.SurveyEngine.addOnUnload(function()\n{\n\t\/*Place your JavaScript here to run when the page is unloaded*\/\n\n});","DefaultChoices":false,"QuestionType":"DB","Selector":"TB","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText"},"QuestionDescription":"question text edited in javascript ","ChoiceOrder":[],"Validation":{"Settings":{"Type":"None"}},"GradingData":[],"Language":[],"NextChoiceId":4,"NextAnswerId":1,"DisplayLogic":{"0":{"0":{"Description":"<span class=\"Co