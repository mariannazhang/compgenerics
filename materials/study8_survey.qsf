a\" height=\"540\" preload=\"auto\" width=\"720\"&gt;video video video video class=\"qmedia\" controls=\"true\" height=\"540\" preload=\"auto\" width=\"720\"&gt;<source type=\"video\/mp4\" src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_blokP4ZgUflzfng\"><\/video>","QuestionText_Unsafe":"<div style=\"text-align: center;\">&nbsp;<\/div>\n\n<div style=\"text-align: center;\">A fictional anthropologist is exploring a new area. Going into this new place, he doesn't know anything about who lives there or what he might find. After being there for one day, he wrote down the following notes after observing an individual from each of the many groups of people who live there.<br>\n&nbsp; <img height=\"221\" src=\"https:\/\/nyu.qualtrics.com\/CP\/Graphic.php?IM=IM_ey5LM0TpAKEdsou\" style=\"width: 280px; height: 221px;\" width=\"280\"><\/div>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID49","SecondaryAttribute":"Based on what you just heard, how long has the anthropologist been in this new place? You will ha...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1","2"],"Choices":{"1":{"Display":"One day"},"2":{"Display":"Several months"}},"Configuration":{"LabelPosition":"BELOW","QuestionDescriptionOption":"UseText"},"DataExportTag":"Q83","DataVisibility":{"Hidden":false,"Private":false},"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Based on what you just heard, how long has the anthropologist been in this new place? You will ha...","QuestionID":"QID49","QuestionText":"<div style=\"text-align: center;\">Based on what you just heard, how long has the anthropologist been in this new place?<\/div>\n\n<div style=\"text-align: center;\"><i>You will have 2 opportunities to get this question correct.<\/i><\/div>","QuestionText_Unsafe":"<div style=\"text-align: center;\">Based on what you have just read, how long has the anthropologist been in this new place?<\/div>\n\n<div style=\"text-align: center;\">Please re-read the passage if you are not sure, you will have 2 opportunities to get this question correct.<\/div>","QuestionType":"MC","Randomization":{"Advanced":null,"TotalRandSubset":"","Type":"All"},"Selector":"SAHR","SubSelector":"TX","Validation":{"Settings":{"ForceResponse":"RequestResponse","ForceResponseType":"RequestResponse","Type":"None","CustomValidation":{"Logic":{"0":{"0":{"ChoiceLocator":"q:\/\/QID90\/SelectableChoice\/1","Description":"<span class=\"ConjDesc\">If<\/span> <span class=\"QuestionDesc\">How long has the anthropologist been in this new place?<\/span> <span class=\"LeftOpDesc\">One day<\/span> <span class=\"OpDesc\">Is Selected<\/span> ","LeftOperand":"q:\/\/QID90\/SelectableChoice\/1","LogicType":"Question","Operator":"Selected","QuestionID":"QID90","QuestionIDFromLocator":"QID90","QuestionIsInLoop":"no","Type":"Expression"},"Type":"If"},"Type":"BooleanExpression"},"Message":{"description":"Wrong choice one day","libraryID":"UR_cBkIfNIPJ4PHE5U","messageID":"MS_eR4223l7cCLwFoi","subMessageID":"VE_CUSTOM_VALIDATION_0"}}}}}},{"SurveyID":"SV_eCL8bIiwGScAj7o","Element":"SQ","PrimaryAttribute":"QID5","SecondaryAttribute":"Agreement to Participate To consent to participate, please click \u201cI consent\u201d below, and enter yo","TertiaryAttribute":null,"Payload":{"ChoiceOrder":["1"],"Choices":{"1":{"Display":"I consent."}},"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q181","DataVisibility":{"Hidden":false,"Private":false},"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"Agreement to Participate To consent to participate, please click \u201cI consent\u201d below, and enter you...","QuestionID":"QID5","QuestionText":"<h2>Agreement to Participate<\/h2>\n<br>\nTo consent to participate, please click \u201cI consent\u201d below, and enter your Prolific ID.","QuestionText_Unsafe":"<h2>Agreement to Participate<\/h2>\n<br>\nTo consent to participa