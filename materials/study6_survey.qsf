iming","QuestionType":"Timing","Selector":"PageTimer"}},{"SurveyID":"SV_39sMcIdV2KANuo6","Element":"SQ","PrimaryAttribute":"QID38","SecondaryAttribute":"video class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\" video video video video class=\"qmedi...","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q29","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"video class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\" video video video video class=\"qmedi...","QuestionID":"QID38","QuestionText":"<video autoplay=\"\">\n  <source type=\"video\/mp4\" src=\"movie.mp4\">\n  <source type=\"video\/ogg\" src=\"movie.ogg\">\nvideo class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\"&gt;video video video video class=\"qmedia\" controls=\"true\" height=\"480\" preload=\"auto\" width=\"640\"&gt;<source type=\"video\/mp4\" src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_eIDGomN4dofuVNQ\"><\/video>","QuestionText_Unsafe":"<video autoplay=\"\">\n  <source src=\"movie.mp4\" type=\"video\/mp4\">\n  <source src=\"movie.ogg\" type=\"video\/ogg\">\nvideo class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\"&gtheight=\"480\" video class=\"qmedia\" controls=\"true\" height=\"480\" preload=\"auto\" width=\"640\"><source src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_37NKz8R6hVn0Arb\" type=\"video\/mp4\" \/><embed align=\"middle\" autoplay=\"false\" bgcolor=\"white\" class=\"qmedia\" controller=\"true\" height=\"480\" pluginspage=\"http:\/\/www.apple.com\/quicktime\/download\/\" src=\"https:\/\/nyu.qualtrics.com\/CP\/File.php?F=F_37NKz8R6hVn0Arb\" type=\"video\/quicktime\" width=\"640\" \/><\/video>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_39sMcIdV2KANuo6","Element":"SQ","PrimaryAttribute":"QID39","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"Configuration":{"MaxSeconds":12,"MinSeconds":12,"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q31","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":704,"QuestionDescription":"Timing","QuestionID":"QID39","QuestionText":"Timing","QuestionText_Unsafe":"Timing","QuestionType":"Timing","Selector":"PageTimer"}},{"SurveyID":"SV_39sMcIdV2KANuo6","Element":"SQ","PrimaryAttribute":"QID4","SecondaryAttribute":"\u00a0 Department of Psychology 6 Washington Place, Room 329 New York, NY 10003-6634 P: (212) 998-3546..","TertiaryAttribute":null,"Payload":{"ChoiceOrder":[],"Configuration":{"QuestionDescriptionOption":"UseText"},"DataExportTag":"Q184","DataVisibility":{"Hidden":false,"Private":false},"DefaultChoices":false,"GradingData":[],"Language":[],"NextAnswerId":1,"NextChoiceId":4,"QuestionDescription":"\u00a0 Department of Psychology 6 Washington Place, Room 329 New York, NY 10003-6634 P: (212) 998-3546...","QuestionID":"QID4","QuestionText":"<p style=\"text-align: left;\"><b id=\"docs-internal-guid-5d765fb0-7fff-d4c6-8035-72c0674fd2a1\"><img width=\"286\" src=\"https:\/\/lh4.googleusercontent.com\/SeYieZU_qfVHQx3S_M-nYuXJBqErP5NfCGQPWQX55ZmUgxzONALZYs6_1zabqXpo0AL_iEpr82WfAJFT2cRzjTaoUS0cGEoo_sO8yDz9hEpUXfXSrczD3zAa1MUiEZkQ9tH-waQCMvB9Rkrz433SIdQjBQCHZRPfskAZFSj4bA36Dcl5tNHRAWMQkg\" height=\"29\">&nbsp;<\/b><\/p>\n\n<p dir=\"ltr\">Department of Psychology<br>\n6 Washington Place, Room 329<br>\nNew York, NY 10003-6634<br>\nP: (212) 998-3546<\/p>\n\n<h2>&nbsp;<\/h2>\n\n<h2 style=\"text-align: center;\"><strong>Consent Form for IRB-FY2023-6812<\/strong><\/h2>\n\n<div style=\"text-align: center;\"><br>\nYou have been invited to take part in a research study to learn more about the relationship between language and how generalizable people think properties are among group members. This study will be conducted by Dr. Marjorie Rhodes and Jessica Stephenson, FAS - Psychology, Arts &amp; Science, New York University.<br>\n<br>\nIf you agree to be in this study, you will watch several short videos and answer some questions.&nbsp;<\/div><div style=\"text-align: center;\"><br>\nThere are no known risks associated with your participation in this research beyond those of everyday life. Although you will receive no direct benefits, this research may help the investigator understand the relationship between language and social essentialism. You will be paid $1.00 for completing this survey. If you withdraw before the end of the study, no compensation will be provided.<br>\n<br>\nConfidentiality of your research records will be strictly maintained by giving all subject data a random numerical code. Information not containing identifiers may be used in future research, shared with other researchers, or placed in a data repository without your additional consent.&nbsp;<br>\n<br>\nParticipation in this study is voluntary. You may refuse to participate or withdraw at any time without penalty. You have the right to skip or not answer any questions you prefer not to answer.<br>\n<br>\nIf there is anything about the study or your participation that is unclear or that you do not understand, if you have questions or wish to report a research-related problem, you may contact Jessica Stephenson at (212) 998-3546, jess.stephenson@nyu.edu or Dr. Marjorie Rhodes at (212) 998-3546, marjorie.rhodes@nyu.edu.&nbsp;<br>\n<br>\nFor questions about your rights as a research participant, you may contact the University Committee on Activities Involving Human Subjects (UCAIHS), New York University, 665 Broadway, Suite 804, New York, New York, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please reference the study # (IRB-FY2023-6812) when contacting the IRB (UCAIHS).<br>\n<br>\nYou may now print a copy of this consent document to keep.<\/div>","QuestionText_Unsafe":"<p style=\"text-align: left;\"><b id=\"docs-internal-guid-5d765fb0-7fff-d4c6-8035-72c0674fd2a1\"><img width=\"286\" src=\"https:\/\/lh4.googleusercontent.com\/SeYieZU_qfVHQx3S_M-nYuXJBqErP5NfCGQPWQX55ZmUgxzONALZYs6_1zabqXpo0AL_iEpr82WfAJFT2cRzjTaoUS0cGEoo_sO8yDz9hEpUXfXSrczD3zAa1MUiEZkQ9tH-waQCMvB9Rkrz433SIdQjBQCHZRPfskAZFSj4bA36Dcl5tNHRAWMQkg\" height=\"29\">&nbsp;<\/b><\/p>\n\n<p dir=\"ltr\">Department of Psychology<br>\n6 Washington Place, Room 329<br>\nNew York, NY 10003-6634<br>\nP: (212) 998-3546<\/p>\n\n<h2>&nbsp;<\/h2>\n\n<h2 style=\"text-align: center;\"><strong>Consent Form for IRB-FY2023-6812<\/strong><\/h2>\n\n<div style=\"text-align: center;\"><br>\nYou have been invited to take part in a research study to learn more about the relationship between language and how generalizable people think properties are among group members. This study will be conducted by Dr. Marjorie Rhodes and Jessica Stephenson, FAS - Psychology, Arts &amp; Science, New York University.<br>\n<br>\nIf you agree to be in this study, you will watch a video and then be asked to read several passages about a fictional anthropologist and answer questions using a slider. Participation in this study will take approximately 3 minutes.&nbsp;<\/div><div style=\"text-align: center;\"><br>\nThere are no known risks associated with your participation in this research beyond those of everyday life. Although you will receive no direct benefits, this research may help the investigator understand the relationship between language and social essentialism. You will be paid $0.60 for completing this survey. If you withdraw before the end of the study, no compensation will be provided.<br>\n<br>\nConfidentiality of your research records will be strictly maintained by giving all subject data a random numerical code. Information not containing identifiers may be used in future research, shared with other researchers, or placed in a data repository without your additional consent.&nbsp;<br>\n<br>\nParticipation in this study is voluntary. You may refuse to participate or withdraw at any time without penalty. You have the right to skip or not answer any questions you prefer not to answer.<br>\n<br>\nIf there is anything about the study or your participation that is unclear or that you do not understand, if you have questions or wish to report a research-related problem, you may contact Jessica Stephenson at (212) 998-3546, jess.stephenson@nyu.edu or Dr. Marjorie Rhodes at (212) 998-3546, marjorie.rhodes@nyu.edu.&nbsp;<br>\n<br>\nFor questions about your rights as a research participant, you may contact the University Committee on Activities Involving Human Subjects (UCAIHS), New York University, 665 Broadway, Suite 804, New York, New York, 10012, at ask.humansubjects@nyu.edu or (212) 998-4808. Please reference the study # (IRB-FY2023-6812) when contacting the IRB (UCAIHS).<br>\n<br>\nYou may now print a copy of this consent document to keep.<\/div>","QuestionType":"DB","Selector":"TB","Validation":{"Settings":{"Type":"None"}}}},{"SurveyID":"SV_39sMcIdV2KANuo6","Element":"SQ","PrimaryAttribute":"QID40","SecondaryAttribute":"Timing","TertiaryAttribute":null,"Payload":{"QuestionText":"Timing","DefaultChoices":false,"DataExportTag":"Q40","QuestionType":"Timing","Selector":"PageTimer","DataVisibility":{"Private":false,"Hidden":false},"Configuration":{"QuestionDescriptionOption":"UseText","MinSeconds":12,"MaxSeconds":12},"QuestionDescription":"Timing","Choices":{"1":{"Display":"First Click"},"2":{"Display":"Last Click"},"3":{"Display":"Page Submit"},"4":{"Display":"Click Count"}},"GradingData":[],"Language":[],"NextChoiceId":588,"NextAnswerId":1,"QuestionID":"QID40"}},{"SurveyID":"SV_39sMcIdV2KANuo6","Element":"SQ","PrimaryAttribute":"QID42","SecondaryAttribute":"video class=\"qmedia\" height=\"540\" preload=\"auto\" width=\"720\" video video video video class=\"qmedi...","TertiaryAttribute":nul